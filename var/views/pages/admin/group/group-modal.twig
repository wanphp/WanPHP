{% extends "pages/common/modal.twig" %}

{% block modal_body %}
  <form hx-post="{{ action }}"
        hx-swap="none" {# 我们手动处理响应，不需要 HTMX 自动替换内容 #}
        class="needs-validation"
        data-modal-form
        data-reset {# 如果需要重置 #}
        data-reload-datatable="admin-group-table" {# 对应你的 DataTable key #}
        novalidate>
    <div class="form-group pb-2">
      <label for="name" class="form-label">分组名称</label>
      <input id="name" name="name" value="{{ group.name }}" type="text" class="form-control" required
             placeholder="填写分组名称"
             autocomplete="off">
      <div class="invalid-feedback">请填写分组名称</div>
    </div>
    <div class="form-group">
      <label for="description" class="form-label">分组说明</label>
      <textarea id="description" name="description" type="text" class="form-control" required placeholder="填写分组说明"
                autocomplete="off">{{ group.description }}</textarea>
      <div class="invalid-feedback">请填写分组说明</div>
    </div>
    <div class="form-group pb-2">
      <label for="displayOrder" class="form-label">显示排序</label>
      <input id="displayOrder" name="displayOrder" value="{{ group.desplayOrder }}" type="number" class="form-control"
             placeholder="填写显示排序"
             autocomplete="off">
      <div class="invalid-feedback">请填写显示排序</div>
    </div>
    <div class="d-grid gap-2 mt-3 col-6 mx-auto">
      <button type="submit" class="btn btn-primary">提交</button>
    </div>
  </form>
{% endblock %}