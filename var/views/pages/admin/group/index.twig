<div data-page="app.admin.group" class="card">
  <div class="card-header">
    <h3 class="card-title">{{ title }}</h3>

    <div class="card-tools">
      <button type="button" class="btn btn-tool open-modal"
              hx-get="{{ url_for('app.admin.group.add') }}"
              hx-target="body"
              hx-swap="beforeend"
              hx-select="unset"
              data-modal-name="app.admin.group.modal"
              data-modal-backdrop="static"
              data-bs-toggle="tooltip" data-bs-title="添加管理员分组">
        <i class="fas fa-people-group"></i>添加
      </button>
    </div>
  </div>

  <div class="card-body">
    <table id="admin-group-table" data-action="{{ url_for('app.admin.group') }}"
           class="table table-sm table-bordered"></table>
  </div>
  <!-- /.card-body -->
</div>
<!-- /.card -->
