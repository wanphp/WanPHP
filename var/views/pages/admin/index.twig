<div data-page="app.admin" class="card">
  <div class="card-header">
    <h3 class="card-title">系统管理员</h3>

    <div class="card-tools">
      <button type="button" class="btn btn-tool open-modal"
              hx-get="{{ url_for('app.admin.add') }}"
              hx-target="body"
              hx-swap="beforeend"
              hx-select="unset"
              data-modal-name="app.admin.modal"
              data-modal-size="lg"
              data-modal-backdrop="static"
              data-bs-toggle="tooltip" data-bs-title="添加管理员">
        <i class="fas fa-user-plus"></i>添加
      </button>
    </div>
  </div>
  <div class="card-header d-flex">
    <div class="dropdown me-3">
      <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        管理角色
      </button>
      <ul class="dropdown-menu">
        {% for id, name in roles %}
          <li><a class="dropdown-item" href="#" data-type="role" data-id="{{ id }}">{{ name }}</a></li>
        {% endfor %}
      </ul>
    </div>
    <div class="dropdown">
      <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        管理分组
      </button>
      <ul class="dropdown-menu">
        {% for id, name in group %}
          <li><a class="dropdown-item" href="#" data-type="group" data-id="{{ id }}">{{ name }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="card-body">
    <table id="admin-table" data-action="{{ url_for('app.admin.list') }}"
           class="table table-sm table-bordered table-hover nowrap"></table>
  </div>
  <!-- /.card-body -->
</div>
<!-- /.card -->