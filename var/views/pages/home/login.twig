<!doctype html>
<html lang="zh">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <title>登录管理系统 | 登录</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes"/>
  <link rel="stylesheet" href="{{ app_css_path }}"/>
  <script type="module" src="{{ app_js_path }}"></script>
  <style>
      .modal-body svg {
          max-width: 100%;
          height: auto;
      }
  </style>
</head>
<body class="login-page bg-body-secondary">
<div data-page="app.login" class="login-box">
  <div class="login-logo">{{ systemName }}</div>
  <div class="card">
    <div class="card-header text-center">
      <h1 class="h1">登录管理系统</h1>
    </div>
    <div class="card-body login-card-body">
      <form hx-post="{{ url_for('app.login') }}" hx-swap="none" class="needs-validation" novalidate>
        <div class="input-group mb-3 has-validation">
          <div class="input-group-text"><span class="fas fa-user"></span></div>
          <input name="account" type="text" class="form-control" placeholder="输入登录帐号" autocomplete="off" required
                 pattern="^[A-Za-z\u4e00-\u9fa5][A-Za-z\d\u4e00-\u9fa5_.]{1,8}$">
          <div class="invalid-feedback">账号必须以字母或中文开头，长度2-10位</div>
        </div>
        <div class="input-group mb-3 has-validation">
          <div class="input-group-text"><span class="fas fa-lock"></span></div>
          <input name="password" type="password" class="form-control" placeholder="请输入帐号密码" required
                 pattern="^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[!@#$%^&*])[A-Za-z\d!@#$%^&*]{8,16}$">
          <div class="invalid-feedback">
            密码必须包含至少一个大写字母，一个小写字母，一个数字和一个特殊字符!@#$%^&*，长度8-16位
          </div>
        </div>
        <div class="social-auth-links text-center mb-3 d-grid gap-2">
          <button type="submit" class="btn btn-primary"><i class="fas fa-key"></i> 登录</button>
          {% if redirect_uri %}
            <a class="btn btn-success" href="{{ redirect_uri }}" role="button"><i class="fab fa-weixin mr-2"></i> 微信登录</a>
          {% else %}
            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#qrLoginModal">
              <i class="fab fa-weixin mr-2"></i> 微信登录</button>
          {% endif %}
        </div>
      </form>
    </div>
    <!-- /.login-card-body -->
  </div>
  {% if loginQr  %}
    <div class="modal fade" id="qrLoginModal" data-action="{{ url_for('app.qrLogin') }}" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h1 class="modal-title fs-5">微信扫一扫登录</h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="row text-center">
              {{ loginQr | raw }}
            </div>
          </div>
          <div class="modal-footer">
            微信扫描二维码授权登录
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>
<!-- /.login-box -->
</body>
</html>
