{% extends "pages/common/modal.twig" %}

{% block modal_body %}
  <form hx-post="{{ action }}"
        hx-swap="none"
        hx-headers='{"HX-Trigger": "refresh-page"}'
        class="needs-validation"
        data-modal-form
        data-reset
        novalidate>
    <div class="row g-3 pb-2 align-items-center">
      <div class="col-auto">
        <label for="name" class="col-form-label" style="width: 64px;">名称</label>
      </div>
      <div class="col-auto">
        <input type="text" id="name" name="name" value="{{ client.name }}" class="form-control" required
               style="width: 204px">
      </div>
      <div class="col-auto">
        <span class="form-text">客户端名称</span>
      </div>
    </div>
    <div class="row g-3 pb-2 align-items-center">
      <div class="col-auto">
        <label for="client_id" class="col-form-label" style="width: 64px;">APPID</label>
      </div>
      <div class="col-auto">
        <input type="text" id="client_id" name="client_id" value="{{ client.client_id }}" class="form-control" required
               autocomplete="off" pattern="^[a-z][a-z\d_]{5,20}$" style="width: 204px">
      </div>
      <div class="col-auto">
        <span class="form-text">客户端ID</span>
      </div>
    </div>
    <div class="row g-3 pb-2 align-items-center">
      <div class="col-auto"><label for="redirect_uri" class="col-form-label">回调地址</label></div>
      <div class="col-auto">
        <input type="url" id="redirect_uri" name="redirect_uri" value="{{ client.redirect_uri }}" class="form-control"
               required
               autocomplete="off" style="width: 204px">
      </div>
      <div class="col-auto"><span class="form-text">授权回调地址</span></div>
    </div>
    <div class="row g-3 pb-2 align-items-center">
      <div class="col-auto"><label for="client_ip" class="col-form-label">客户端IP</label></div>
      <div class="col-auto">
        <input type="text" id="client_ip" name="client_ip" value="{{ client.client_ip | join(',') }}"
               class="form-control" required
               pattern="^(\s*((25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)(\.(25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)){3})\s*)(,\s*((25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)(\.(25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)){3})\s*)*$"
               autocomplete="off" style="width: 204px">
      </div>
      <div class="col-auto"><span class="form-text">请输入合法 IPv4 地址，多个用英文逗号分隔</span></div>
    </div>
    <div class="row g-3 pb-2 align-items-center">
      <div class="col-auto"><label for="confidential" class="col-form-label">验证方式</label></div>
      <div class="col-auto">
        <select id="confidential" name="confidential" class="form-select" style="width: 204px">
          <option value="0">开放</option>
          <option value="1"{{ client.confidential?' selected':'' }}>私密</option>
        </select>
      </div>
      <div class="col-auto"><span class="form-text">授权验证方式</span></div>
    </div>
    <div class="from-group mb-3">
      <label for="scopes">授权范围</label>
      <select class="form-select" id="scopes" name="scopes[]" multiple>
        {% for scope in scopes %}
          <option value="{{ scope.identifier }}"
              {{ scope.identifier in client.scopes ? 'selected' : '' }}>{{ scope.name }}</option>
        {% endfor %}
      </select>
    </div>

    <div class="d-grid gap-2 mt-3 col-6 mx-auto">
      <button type="submit" class="btn btn-primary">提交</button>
    </div>
  </form>
{% endblock %}