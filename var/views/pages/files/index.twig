<div data-page="app.files" class="card">
  <div class="card-header">
    <h3 class="card-title">{{ title }}</h3>

    <div class="card-tools">
      <button type="button" class="btn btn-tool" data-action="{{ url_for('app.file.upload') }}"
              data-bs-toggle="tooltip" data-bs-title="上传文件">
        <i class="fas fa-upload"></i>上传
      </button>
    </div>
  </div>
  <div class="card-body">
    <table id="files-table" data-action="{{ url_for('app.files') }}"
           class="table table-sm table-bordered table-hover">
    </table>
  </div>
  <!-- /.card-body -->
</div>
<!-- /.card -->
