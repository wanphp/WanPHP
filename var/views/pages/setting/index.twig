<div data-page="app.setting" class="card" hx-get="{{ url_for('app.setting') }}" hx-trigger="refresh-page from:body"
     hx-target="this" hx-swap="outerHTML">
  <div class="card-header">
    <h3 class="card-title">{{ title }}</h3>

    <div class="card-tools">
      <button type="button" class="btn btn-tool open-modal"
              hx-get="{{ url_for('app.setting.add') }}"
              hx-target="body"
              hx-swap="beforeend"
              hx-select="unset"
              hx-disabled-elt="this"
              data-modal-name="app.setting.modal"
              data-modal-size="lg"
              data-modal-backdrop="static"
              data-bs-toggle="tooltip" data-bs-title="添加系统配置">
        <i class="fas fa-plus-circle"></i>添加
      </button>
    </div>
  </div>
  <div class="card-body">
    <table class="table table-sm table-bordered table-hover nowrap">
      <thead>
      <tr>
        <th>配置名称</th>
        <th>键名</th>
        <th>键值</th>
        <th>操作</th>
      </tr>
      </thead>
      <tbody>
      {% for setting in settings %}
        <tr class="align-middle">
          <td>{{ setting.name }}</td>
          <td>{{ setting.key }}</td>
          <td>
            {% if setting.value matches '/\\.(jpg|jpeg|png|gif|webp)$/i' %}
              <img src="{{ setting.value }}" class="img-fluid rounded border" alt="{{ setting.name }}"
                   style="height: 50px;">
            {% else %}
              {{ setting.value }}
            {% endif %}
          </td>
          <td>
            <div class="btn-group btn-group-sm">
              <button type="button" class="btn btn-primary edit" data-bs-toggle="tooltip" data-bs-title="修改"
                      hx-get="{{ url_for('app.setting.edit',{id:setting.id}) }}"
                      hx-target="body"
                      hx-swap="beforeend"
                      hx-select="unset"
                      hx-disabled-elt="this"
                      data-modal-name="app.setting.modal"
                      data-modal-size="lg"
                      data-modal-backdrop="static">
                <i class="fas fa-edit"></i></button>
              <button type="button" class="btn btn-danger delete" data-bs-toggle="tooltip" data-bs-title="删除"
                      hx-delete="{{ url_for('app.setting.delete',{id:setting.id}) }}"
                      hx-disabled-elt="this"
                      hx-confirm="是否确认要删除配置?"
                      hx-swap="none" hx-headers='{"Hx-Trigger": "refresh-page"}'>
                <i class="fas fa-trash-alt"></i></button>
            </div>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
  <!-- /.card-body -->
</div>
<!-- /.card -->
