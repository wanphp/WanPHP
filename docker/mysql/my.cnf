[mysqld]
# --- 基础设置 ---
user = mysql
datadir = /var/lib/mysql
socket = /var/run/mysqld/mysqld.sock
# 建议设为 1 (Linux标准)，所有表名在存储时都转为小写，比较时也不区分大小写。
lower_case_table_names = 1

# --- 字符集与时区 ---
character-set-server = utf8mb4
collation-server = utf8mb4_0900_ai_ci
default-time-zone = '+08:00'

# --- SQL 模式 ---
# 显式包含严格模式
sql_mode = "STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,ONLY_FULL_GROUP_BY,NO_ENGINE_SUBSTITUTION"

# --- 网络与连接 ---
max_connections = 500         # 增加并发支持
wait_timeout = 600
interactive_timeout = 600
skip-name-resolve             # 禁用DNS解析，防止连接慢

# --- 内存与性能优化 (针对 8GB 物理内存) ---
# 数据库核心内存，建议分配总内存的 40%-50%
innodb_buffer_pool_size = 3G
# 刷盘策略：1最安全，0或2性能更高但掉电可能丢1秒数据
innodb_flush_log_at_trx_commit = 1
# 提升磁盘 IO 效率
innodb_flush_method = O_DIRECT
# 重做日志大小
innodb_redo_log_capacity = 512M
innodb_log_buffer_size = 16M
# 临时表内存限制
tmp_table_size = 64M
max_heap_table_size = 64M

# --- 日志 ---
general_log = 0
slow_query_log = 1
slow_query_log_file = /var/lib/mysql/slow.log
long_query_time = 1

# --- 安全与稳定性 ---
# 禁用符号链接以防安全漏洞
symbolic-links = 0
# 解决 PID 文件路径警告
pid-file = /var/run/mysqld/mysqld.pid

[client]
default-character-set = utf8mb4