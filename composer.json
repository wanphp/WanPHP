{
  "name": "wanphp/slim",
  "description": "Wan php Slim Framework for development",
  "keywords": [
    "microframework"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "火子",
      "email": "wanphp@outlook.com",
      "homepage": "https://www.wanphp.com/"
    }
  ],
  "require": {
    "monolog/monolog": "^2.2",
    "wanphp/core": "v2.0.0-alpha",
    "matomo/device-detector": "^6.5",
    "zircote/swagger-php": "^5.5.0",
    "ext-pdo": "*",
    "ext-redis": "*",
    "ext-dom": "*",
    "ext-libxml": "*"
  },
  "config": {
    "process-timeout": 0,
    "sort-packages": true,
    "allow-plugins": {
      "wanphp/installers": true
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  }
}
